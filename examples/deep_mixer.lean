open AmoLean.Matrix (MatExpr)

-- A 50-round mixing network on 16 elements.
-- Each round: adjacent-pair butterflies, then strided butterflies.
-- That's 100 matrix operations (50 × 2 stages composed together).
def spec : MatExpr Int 16 16 :=
  let adj     : MatExpr Int 16 16 := .kron (.identity 8) (.dft 2)
  let stride2 : MatExpr Int 16 16 := .kron (.identity 4) (.kron (.dft 2) (.identity 2))
  let stride4 : MatExpr Int 16 16 := .kron (.identity 2) (.kron (.dft 2) (.identity 4))
  let stride8 : MatExpr Int 16 16 := .kron (.dft 2) (.identity 8)
  let round (a b : MatExpr Int 16 16) : MatExpr Int 16 16 := .compose b a
  -- Round pattern: adj → stride2 → adj → stride4 → adj → stride8, repeat
  let r1  := round adj stride2
  let r2  := round r1 adj
  let r3  := round r2 stride4
  let r4  := round r3 adj
  let r5  := round r4 stride8
  let r6  := round r5 adj
  let r7  := round r6 stride2
  let r8  := round r7 adj
  let r9  := round r8 stride4
  let r10 := round r9 adj
  let r11 := round r10 stride8
  let r12 := round r11 adj
  let r13 := round r12 stride2
  let r14 := round r13 adj
  let r15 := round r14 stride4
  let r16 := round r15 adj
  let r17 := round r16 stride8
