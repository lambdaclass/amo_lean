  let Пү := getPrimitiveRoot n
  let twiddles := genTwiddleTable Пү n

  -- Verify Пү^0 = 1
  let t0_ok := optVal twiddles[0]? == 1
  IO.println s!"в”Ӯ Пү^0 = 1 ? {if t0_ok then "вң“ PASS" else "вң— FAIL"}"
  if !t0_ok then allPassed := false

  -- Verify Пү^(n/2) = -1
  let tn2_ok := optVal twiddles[n/2]? == ORDER - 1
  IO.println s!"в”Ӯ Пү^{n/2} = -1 ? {if tn2_ok then "вң“ PASS" else "вң— FAIL"}"
  if !tn2_ok then allPassed := false

  -- Verify Пү^n would equal Пү^0
  let wn := GoldilocksField.pow Пү n
  let cycle_ok := wn.value == 1
  IO.println s!"в”Ӯ Пү^{n} = 1 (cycle) ? {if cycle_ok then "вң“ PASS" else "вң— FAIL"}"
  if !cycle_ok then allPassed := false

  IO.println "в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ"

  IO.println "\nв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ"
  if allPassed then
    IO.println "   RESULT: ALL ALGEBRA TESTS PASSED вң“"
  else
    IO.println "   RESULT: SOME TESTS FAILED вң—"
  IO.println "в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ"

  return allPassed

end AmoLean.NTT.Tests.Algebra
